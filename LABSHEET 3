# 5️ Inventory Stock List


stock = {}

def add():
    item = input("Item: ")
    qty = int(input("Qty: "))
    stock[item] = stock.get(item,0)+qty

def sell():
    item = input("Item: ")
    qty = int(input("Qty: "))
    if item in stock:
        stock[item] -= qty

def low():
    for i,q in stock.items():
        print(i,"Low Stock" if q<5 else q)

while True:
    print("1 Add 2 Sell 3 LowStock 4 Exit")
    ch = int(input())

    if ch==1: add()
    elif ch==2: sell()
    elif ch==3: low()
    else: break


