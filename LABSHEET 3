# 8️ To-Do Task Manager

tasks = []

def add():
    tasks.append([input("Task: "),"Pending"])

def remove():
    t = input("Task name: ")
    for task in tasks:
        if task[0]==t:
            tasks.remove(task)

def complete():
    t = input("Task name: ")
    for task in tasks:
        if task[0]==t:
            task[1]="Done"

def show():
    for t in tasks:
        print(t[0], "Done" if t[1]=="Done" else "Pending")

while True:
    print("1 Add 2 Remove 3 Complete 4 Show 5 Exit")
    ch=int(input())

    if ch==1:add()
    elif ch==2:remove()
    elif ch==3:complete()
    elif ch==4:show()
    else:break


