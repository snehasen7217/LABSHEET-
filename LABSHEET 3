# 1️ Shopping Cart Using List


cart = []

def add_item():
    name = input("Product name: ")
    price = float(input("Price: "))
    qty = int(input("Quantity: "))
    cart.append([name, price, qty])

def remove_item():
    name = input("Enter product to remove: ")
    for item in cart:
        if item[0] == name:
            cart.remove(item)

def update_qty():
    name = input("Product name: ")
    for item in cart:
        if item[0] == name:
            item[2] = int(input("New quantity: "))

def bill():
    total = 0
    for item in cart:
        total += item[1]*item[2]
    print("Total Bill:", total)

while True:
    print("1 Add 2 Remove 3 Update 4 Bill 5 Exit")
    ch = int(input())

    if ch == 1:
        add_item()
    elif ch == 2:
        remove_item()
    elif ch == 3:
        update_qty()
    elif ch == 4:
        print("Cart Empty" if len(cart)==0 else cart)
        bill()
    else:
        break


# 2️  Student Marks Analysis

marks = []

def add_marks():
    marks.append(int(input("Enter marks: ")))

def average():
    print("Average:", sum(marks)/len(marks))

def high_low():
    print("Highest:", max(marks))
    print("Lowest:", min(marks))

def pass_fail():
    for m in marks:
        print(m, "Pass" if m>=40 else "Fail")

while True:
    print("1 Add 2 Avg 3 HighLow 4 PassFail 5 Exit")
    ch = int(input())

    if ch==1: add_marks()
    elif ch==2: average()
    elif ch==3: high_low()
    elif ch==4: pass_fail()
    else: break


