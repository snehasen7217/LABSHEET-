# 9. Prime Number Checker


def is_prime(n):
    if n <= 1:
        return False

    for i in range(2,n):
        if n%i == 0:
            return False
    return True

while True:
    num = int(input("Enter number: "))

    if num == 0:
        break

    if num <= 0:
        continue

    if is_prime(num):
        print(num,"is Prime")
    else:
        print(num,"is Not Prime")


